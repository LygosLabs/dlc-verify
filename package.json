{
  "name": "dlc-verify",
  "version": "1.0.0",
  "description": "Open-source DLC verification tool for independently verifying Discreet Log Contract messages before signing",
  "main": "dist/verify.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "verify": "node dist/verify.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/"
  },
  "keywords": [
    "dlc",
    "bitcoin",
    "discreet-log-contracts",
    "verification",
    "adaptor-signatures"
  ],
  "author": "Lygos Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LygosLabs/dlc-verify"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "commonjs",
  "dependencies": {
    "@atomicfinance/bitcoin-cfd-provider": "^4.2.7",
    "@atomicfinance/bitcoin-dlc-provider": "^4.2.7",
    "@atomicfinance/client": "^4.2.7",
    "@bennyblader/ddk-ts": "^0.3.35",
    "@node-dlc/core": "^1.1.7",
    "@node-dlc/messaging": "^1.1.7",
    "bip-schnorr": "^0.6.7",
    "bitcoin-networks": "^1.0.0",
    "bitcoinjs-lib": "^7.0.1",
    "cfd-dlc-js-wasm": "github:atomicfinance/cfd-dlc-js-wasm#v1.0.6",
    "cfd-js-wasm": "github:atomicfinance/cfd-js-wasm#v0.4.10",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^1.6.1"
  }
}
